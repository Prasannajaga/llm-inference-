    {
      "id": "K7I3aBsUMCI8kKgcRCqJ_",
      "type": "text",
      "x": 380.04141475706126,
      "y": 1001.3138802545275,
      "width": 496.1395568847656,
      "height": 600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "9udLjOo7K7wtbGUCdK1h4",
      "index": "b28",
      "roundness": null,
      "seed": 2085216506,
      "version": 1424,
      "versionNonce": 422205158,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780994778088,
      "link": null,
      "locked": false,
      "text": "\npods = [pod A, pod b, pod C]\nready = []\n\n\nfor pod in pods:\n\n health = checkHealth(pod)\n if health:\n    ready.append(pod)\n\n return ready;\n\n\nSo if pod A died the remaining [B , C] will sent to \nthe Scoring state \n\n\n\n       \n\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\npods = [pod A, pod b, pod C]\nready = []\n\n\nfor pod in pods:\n\n health = checkHealth(pod)\n if health:\n    ready.append(pod)\n\n return ready;\n\n\nSo if pod A died the remaining [B , C] will sent to \nthe Scoring state \n\n\n\n       \n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9udLjOo7K7wtbGUCdK1h4",
