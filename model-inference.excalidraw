    {
      "id": "76edhEZOlTMNhVm5f2-aZ",
      "type": "text",
      "x": 2525.108415758358,
      "y": 1023.6128409675039,
      "width": 557.9194946289062,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "s-cUZ67WryR8bTXeRqdEu",
      "index": "b2ix",
      "roundness": null,
      "seed": 1927627750,
      "version": 444,
      "versionNonce": 1889127610,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781007151521,
      "link": null,
      "locked": false,
      "text": "if single:\n\n    choose pod\n    prefill + decode \n    stream response \n\nelse if disaggregated:\n     \n      choose prefill & decode pod\n      execute prefill\n      wait until done \n      execute decode with KV cache\n      stream response \n\n\nDisaggregated will mostly used for longer context where \nsingle used for small.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if single:\n\n    choose pod\n    prefill + decode \n    stream response \n\nelse if disaggregated:\n     \n      choose prefill & decode pod\n      execute prefill\n      wait until done \n      execute decode with KV cache\n      stream response \n\n\nDisaggregated will mostly used for longer context where \nsingle used for small.",
      "autoResize": true,
      "lineHeight": 1.25
    },
